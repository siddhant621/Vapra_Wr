generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String             @id @default(uuid())
  clerkUserId        String             @unique
  email              String             @unique
  name               String?
  imageUrl           String?
  role               UserRole           @default(CUSTOMER)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  experience         Int?
  specialization     String?
  verificationStatus VerificationStatus @default(PENDING)
  customerBookings   Booking[]          @relation("CustomerBookings")
  mechanicBookings   Booking[]          @relation("MechanicBookings")
  bookingRequests    BookingRequest[]
  payments           Payment[]
  vehicles           Vehicle[]
}

model Vehicle {
  id             String          @id @default(uuid())
  ownerId        String
  brand          String
  model          String
  year           Int
  registrationNo String          @unique
  fuelType       FuelType
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  bookings       Booking[]
  serviceRecords ServiceRecord[]
  owner          User            @relation(fields: [ownerId], references: [id], onDelete: Cascade)
}

model Service {
  id          String    @id @default(uuid())
  name        String
  description String?
  basePrice   Float
  duration    Int
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  bookings    Booking[]
}

model Booking {
  id            String         @id @default(uuid())
  customerId    String
  mechanicId    String?
  vehicleId     String
  serviceId     String
  scheduledAt   DateTime
  status        BookingStatus  @default(SCHEDULED)
  notes         String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  customer      User           @relation("CustomerBookings", fields: [customerId], references: [id])
  mechanic      User?          @relation("MechanicBookings", fields: [mechanicId], references: [id])
  service       Service        @relation(fields: [serviceId], references: [id])
  vehicle       Vehicle        @relation(fields: [vehicleId], references: [id])
  payments      Payment[]
  serviceRecord ServiceRecord?

  @@index([status, scheduledAt])
}

model ServiceRecord {
  id          String   @id @default(uuid())
  vehicleId   String
  bookingId   String?  @unique
  description String?
  cost        Float
  createdAt   DateTime @default(now())
  booking     Booking? @relation(fields: [bookingId], references: [id])
  vehicle     Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
}

model Payment {
  id            String        @id @default(uuid())
  userId        String
  bookingId     String?
  amount        Float
  paymentMethod PaymentMethod
  status        PaymentStatus @default(PAID)
  createdAt     DateTime      @default(now())
  booking       Booking?      @relation(fields: [bookingId], references: [id])
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum UserRole {
  CUSTOMER
  MECHANIC
  ADMIN
}

enum FuelType {
  PETROL
  DIESEL
  ELECTRIC
  HYBRID
  CNG
}

enum BookingStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum PaymentMethod {
  CARD
  UPI
  CASH
  WALLET
}

enum PaymentStatus {
  PAID
  FAILED
  REFUNDED
}

enum VerificationStatus {
  PENDING
  VERIFIED
  REJECTED
}

model BookingRequest {
  id               String   @id @default(uuid())
  customerId       String?
  serviceName      String
  vehicleInfo      String   @db.Text
  issueDescription String   @db.Text
  preferredDate    DateTime
  phone            String
  email            String?
  status           BookingRequestStatus @default(PENDING)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  customer         User?    @relation(fields: [customerId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
}

enum BookingRequestStatus {
  PENDING
  REVIEWED
  ASSIGNED
  CLOSED
}
